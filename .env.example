# Copy this file to .env and replace the placeholder with your real Groq API key.
GROQ_API_KEY=""
# Optional: set path to Tesseract if installed in a custom location.
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Admin credentials for the first user. These are used to bootstrap the admin account if no users exist.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
